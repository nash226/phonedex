{
  "name": "phonedex",
  "version": "0.1.0",
  "private": true,
  "description": "iPhone alerts and dictated replies for completed Codex tasks.",
  "bin": {
    "phonedex": "./bin/codex-watch.js",
    "watchdex": "./bin/codex-watch.js",
    "codex-watch": "./bin/codex-watch.js"
  },
  "scripts": {
    "server": "node ./bin/codex-watch.js server",
    "service": "node ./bin/codex-watch.js service",
    "hook": "node ./bin/codex-watch.js hook",
    "install-hook": "node ./scripts/install-codex-hook.js",
    "ha:install": "bash ./scripts/home-assistant-local.sh install",
    "ha:init-config": "bash ./scripts/home-assistant-local.sh init-config",
    "ha:start": "bash ./scripts/home-assistant-local.sh start",
    "ha:doctor": "bash ./scripts/home-assistant-local.sh doctor",
    "services:install": "bash ./scripts/install-launch-agents.sh install",
    "services:start": "bash ./scripts/install-launch-agents.sh start",
    "services:stop": "bash ./scripts/install-launch-agents.sh stop",
    "services:status": "bash ./scripts/install-launch-agents.sh status",
    "watch:sessions": "node ./bin/codex-watch.js watch-sessions",
    "scan:sessions": "node ./bin/codex-watch.js scan-sessions",
    "remote:install": "bash ./scripts/home-assistant-remote-tunnel.sh install",
    "remote:start": "bash ./scripts/home-assistant-remote-tunnel.sh start",
    "remote:stop": "bash ./scripts/home-assistant-remote-tunnel.sh stop",
    "remote:status": "bash ./scripts/home-assistant-remote-tunnel.sh status",
    "remote:url": "bash ./scripts/home-assistant-remote-tunnel.sh url",
    "ios:doctor": "bash ./scripts/ios-dev.sh doctor",
    "ios:install-xcode": "bash ./scripts/ios-dev.sh install-xcode",
    "ios:generate": "bash ./scripts/ios-dev.sh generate",
    "ios:open": "bash ./scripts/ios-dev.sh open",
    "test-notify": "node ./bin/codex-watch.js notify --title \"PhoneDex test\" --text \"PhoneDex test notification\"",
    "replies": "node ./bin/codex-watch.js replies",
    "tasks": "node ./bin/codex-watch.js tasks",
    "devices": "node ./bin/codex-watch.js devices",
    "check": "node --check ./bin/codex-watch.js"
  },
  "engines": {
    "node": ">=18"
  }
}
