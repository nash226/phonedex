{
  "name": "phonedex",
  "version": "0.1.0",
  "private": true,
  "description": "iPhone alerts and dictated replies for completed Codex tasks.",
  "bin": {
    "phonedex": "./bin/codex-watch.js",
    "watchdex": "./bin/codex-watch.js",
    "codex-watch": "./bin/codex-watch.js"
  },
  "scripts": {
    "server": "node ./bin/codex-watch.js server",
    "service": "node ./bin/codex-watch.js service",
    "hook": "node ./bin/codex-watch.js hook",
    "install-hook": "node ./scripts/install-codex-hook.js",
    "services:install": "bash ./scripts/install-launch-agents.sh install",
    "services:start": "bash ./scripts/install-launch-agents.sh start",
    "services:stop": "bash ./scripts/install-launch-agents.sh stop",
    "services:status": "bash ./scripts/install-launch-agents.sh status",
    "windows:install": "powershell -ExecutionPolicy Bypass -File ./scripts/install-windows-task.ps1 install",
    "windows:start": "powershell -ExecutionPolicy Bypass -File ./scripts/install-windows-task.ps1 start",
    "windows:stop": "powershell -ExecutionPolicy Bypass -File ./scripts/install-windows-task.ps1 stop",
    "windows:status": "powershell -ExecutionPolicy Bypass -File ./scripts/install-windows-task.ps1 status",
    "windows:uninstall": "powershell -ExecutionPolicy Bypass -File ./scripts/install-windows-task.ps1 uninstall",
    "watch:sessions": "node ./bin/codex-watch.js watch-sessions",
    "scan:sessions": "node ./bin/codex-watch.js scan-sessions",
    "ios:doctor": "bash ./scripts/ios-dev.sh doctor",
    "ios:install-xcode": "bash ./scripts/ios-dev.sh install-xcode",
    "ios:generate": "bash ./scripts/ios-dev.sh generate",
    "ios:open": "bash ./scripts/ios-dev.sh open",
    "test-notify": "node ./bin/codex-watch.js notify --title \"PhoneDex test\" --text \"PhoneDex test notification\"",
    "replies": "node ./bin/codex-watch.js replies",
    "tasks": "node ./bin/codex-watch.js tasks",
    "devices": "node ./bin/codex-watch.js devices",
    "devices:verify": "node ./bin/codex-watch.js verify-devices",
    "devices:alert": "node ./bin/codex-watch.js notify-coverage",
    "agent:enroll": "node ./bin/codex-watch.js enroll-agent",
    "agent:self-test": "node ./bin/codex-watch.js agent-self-test",
    "agent:bundle": "node ./bin/codex-watch.js agent-bundle",
    "agent:invite": "node ./bin/codex-watch.js agent-invite",
    "agent:invites": "node ./bin/codex-watch.js agent-invite --list",
    "pair:create": "node ./bin/codex-watch.js pair:create",
    "pair:rotate": "node ./bin/codex-watch.js pair:rotate",
    "agent:installs": "node ./bin/codex-watch.js agent-installs",
    "test": "npm run test:protocol && npm run test:evidence && npm run test:store && npm run test:recovery && npm run test:sync && npm run test:adapter && npm run test:windows-adapter && npm run test:lifecycle && npm run test:reply-delivery && npm run test:question-response && npm run test:session-watch && npm run test:notification-policy && npm run test:device-coverage && npm run test:coverage-alert && npm run test:agent-enrollment && npm run test:agent-bootstrap-server && npm run test:agent-installs && npm run test:agent-self-test && npm run test:foreground-submit && npm run test:reply-routing && npm run test:privacy && npm run test:compatibility && npm run test:security && npm run test:pairing && npm run test:identity-lifecycle && npm run test:approvals && npm run test:approval-adversarial && npm run test:artifacts && npm run test:ios-privacy-manifest && npm run test:ios-privacy-surfaces && npm run test:release-manifest && npm run test:observability && npm run test:signing-config",
    "test:protocol": "node ./scripts/test-protocol.js",
    "test:evidence": "node ./scripts/test-evidence.js",
    "test:store": "node ./scripts/test-store.js",
    "test:recovery": "node ./scripts/test-recovery.js",
    "test:sync": "node ./scripts/test-sync.js && node ./scripts/test-sync-server.js",
    "test:adapter": "node ./scripts/test-adapter.js",
    "test:windows-adapter": "node ./scripts/test-windows-adapter.js",
    "test:windows-service-lifecycle": "node ./scripts/test-windows-service-lifecycle.js",
    "test:lifecycle": "node ./scripts/test-lifecycle.js",
    "test:reply-delivery": "node ./scripts/test-reply-delivery.js",
    "test:session-watch": "node ./scripts/test-session-watch.js",
    "test:notification-policy": "node ./scripts/test-notification-policy.js",
    "test:device-coverage": "node ./scripts/test-device-coverage.js",
    "test:coverage-alert": "node ./scripts/test-coverage-alert.js",
    "test:agent-enrollment": "node ./scripts/test-agent-enrollment.js",
    "test:agent-bootstrap-server": "node ./scripts/test-agent-bootstrap-server.js",
    "test:agent-installs": "node ./scripts/test-agent-installs.js",
    "test:agent-self-test": "node ./scripts/test-agent-self-test.js",
    "test:foreground-submit": "node ./scripts/test-foreground-submit.js",
    "test:reply-routing": "node ./scripts/test-reply-routing.js",
    "test:question-response": "node ./scripts/test-question-response.js",
    "test:privacy": "node ./scripts/test-privacy.js",
    "test:compatibility": "node ./scripts/test-compatibility.js",
    "test:security": "node ./scripts/test-security.js",
    "test:pairing": "node ./scripts/test-pairing.js",
    "test:identity-lifecycle": "node ./scripts/test-identity-lifecycle.js",
    "test:approvals": "node ./scripts/test-approvals.js",
    "test:approval-adversarial": "node ./scripts/test-approval-adversarial.js",
    "test:artifacts": "node ./scripts/test-artifacts.js",
    "test:ios-privacy-manifest": "node ./scripts/test-ios-privacy-manifest.js",
    "test:ios-privacy-surfaces": "node ./scripts/test-ios-privacy-surfaces.js",
    "test:release-manifest": "node ./scripts/test-release-manifest.js",
    "test:observability": "node ./scripts/test-observability.js",
    "test:signing-config": "node ./scripts/test-signing-config.js",
    "release:manifest": "node ./scripts/release-manifest.js",
    "release:verify": "node ./scripts/release-manifest.js --check",
    "check": "node --check ./bin/codex-watch.js && node --check ./lib/phonedex-store.js && node --check ./lib/phonedex-sync.js && node --check ./lib/phonedex-adapter.js && node --check ./lib/phonedex-artifacts.js && node --check ./lib/phonedex-handoff.js && node --check ./lib/phonedex-lifecycle.js && node --check ./lib/phonedex-security.js && node --check ./scripts/release-manifest.js"
  },
  "engines": {
    "node": ">=18"
  }
}
