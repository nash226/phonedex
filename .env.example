# Copy this file to .env and choose how this machine participates.

# Multi-device mode:
# - Hub Mac: leave PHONEDEX_HUB_URL empty. Point the iPhone app at this server.
# - Agent machines: set PHONEDEX_HUB_URL to the hub's public URL and
#   PHONEDEX_AGENT_MODE=true so this machine forwards Codex completions without
#   also sending its own phone notification.
PHONEDEX_HUB_URL=
PHONEDEX_HUB_TOKEN=
PHONEDEX_AGENT_MODE=false
PHONEDEX_DEVICE_ID=
# Hub-only coverage check. Comma-separated ids; optional display names use
# id:Display Name, for example:
# PHONEDEX_EXPECTED_DEVICES=macbook-air:MacBook Air,windows-desktop:Windows
PHONEDEX_EXPECTED_DEVICES=
PHONEDEX_HEARTBEAT_INTERVAL_MS=30000
PHONEDEX_DEVICE_STALE_MS=120000

# Provider options:
# - pushcut
# - home-assistant (legacy fallback)
WATCH_BRIDGE_PROVIDER=pushcut

# Pushcut webhook copied from the notification you create in the iOS app.
# Example: https://api.pushcut.io/YOUR_SECRET/notifications/codex-task
PUSHCUT_WEBHOOK_URL=

# Home Assistant provider settings.
# HOME_ASSISTANT_NOTIFY_SERVICE can be either notify.mobile_app_your_iphone
# or just mobile_app_your_iphone.
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=
HOME_ASSISTANT_NOTIFY_SERVICE=
HOME_ASSISTANT_INTERRUPTION_LEVEL=time-sensitive
# reply: use Home Assistant's native REPLY text input.
# shortcut: make Custom reply open an Apple Shortcut named PHONEDEX_SHORTCUT_NAME.
HOME_ASSISTANT_CUSTOM_REPLY_MODE=reply
PHONEDEX_SHORTCUT_NAME=PhoneDex Reply

# Public URL that your phone automation can call when you tap an action.
# Same-Wi-Fi example: http://YOUR_MAC_LAN_IP:8765
# Remote example: https://your-cloudflare-or-ngrok-url.example
WATCH_BRIDGE_PUBLIC_URL=http://127.0.0.1:8765

# Human-readable source name shown in notifications.
# Use a different value on each machine, for example "MacBook Air" or "Windows".
PHONEDEX_MACHINE_NAME=
# Legacy alias still supported:
# WATCHDEX_MACHINE_NAME=

# Keep this private. Query/body token required by /reply.
WATCH_BRIDGE_TOKEN=change-me

# Server bind. Use 0.0.0.0 when your iPhone/Watch will call the Mac over LAN.
WATCH_BRIDGE_HOST=127.0.0.1
WATCH_BRIDGE_PORT=8765

# Optional: if true, a phone reply attempts to continue the Codex session.
WATCH_BRIDGE_AUTO_RESUME=false
# Auto-resume modes:
# - cli: runs `codex exec resume <session> <prompt>` in the background.
# - app-server: opens the Codex app-server protocol and starts a turn.
# - foreground: activates Codex.app and submits the prompt in the visible thread.
WATCH_BRIDGE_AUTO_RESUME_MODE=cli
# Optional override for app-server mode. Defaults to ~/.local/bin/codex when present.
CODEX_APP_SERVER_BIN=

# Optional session watcher timing for Codex completions missed by hooks.
WATCHDEX_SESSION_WATCH_INTERVAL_MS=5000
WATCHDEX_SESSION_WATCH_DEBOUNCE_MS=8000
WATCHDEX_SESSION_WATCH_LOOKBACK_HOURS=168
WATCHDEX_SESSION_WATCH_FILE_LIMIT=500

# Optional Pushcut controls.
PUSHCUT_SOUND=jobDone
PUSHCUT_TIME_SENSITIVE=true
